# ── Ollama (local — no API key needed) ────────────────────────────
OLLAMA_HOST=http://localhost:11434
IDENTIFIER_MODEL=llava          # vision model: llava, llava:13b, bakllava
DECOMPOSER_MODEL=llava          # text model: llava | llama3.2 | mistral

# ── Confidence gate ────────────────────────────────────────────────
CONFIDENCE_THRESHOLD=0.65       # below this → UI shows "Confirm?" step
                                 # bypass in URL with ?autoconfirm=1

# ── Pricing grounding ──────────────────────────────────────────────
GROUNDING_MODE=llm              # llm (MVP) | live (v1.1 — requires FRED/BLS keys)

# ── v1.1 price source keys (stubs in MVP — do not activate) ───────
# FRED_API_KEY=your_key_here    # https://fred.stlouisfed.org/docs/api/api_key.html
# BLS_API_KEY=your_key_here     # https://data.bls.gov/registrationEngine/

# ── Server ─────────────────────────────────────────────────────────
PORT=8000
